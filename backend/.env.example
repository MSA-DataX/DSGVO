# --- Scanner ---
SCAN_MAX_DEPTH=1
SCAN_MAX_PAGES=8
SCAN_PAGE_TIMEOUT_MS=20000
SCAN_USER_AGENT="GDPR-Scanner/0.1 (+compliance audit; contact admin)"

# --- AI providers ---
# Pick one. If both are empty, AI analysis is skipped gracefully (the scan
# still returns crawl/network/cookie data with privacy_analysis.provider="none").
AI_PROVIDER=openai                       # openai | azure | none
AI_MAX_POLICY_CHARS=24000                # truncation budget for policy text sent to the model
AI_REQUEST_TIMEOUT_S=60

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                   # e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=                 # the *deployment* name, not the model name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Server ---
HOST=0.0.0.0
PORT=8000

# CORS — dev default is "*". For production, list the frontend origin(s),
# comma-separated, e.g. ALLOWED_ORIGINS=https://scanner.example.com
ALLOWED_ORIGINS=*

# --- Persistence ---
# Default: file-backed SQLite for zero-config local dev.
# Postgres (start the docker-compose service first):
#   DATABASE_URL=postgresql+asyncpg://scanner:scanner@localhost:5432/scanner
DATABASE_URL=sqlite+aiosqlite:///scans.db

# --- Auth (Phase 1.2) ---
# MUST be a strong random value in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-insecure-replace-in-production
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=10080         # 7 days; cut shorter once a refresh-token flow exists

# --- Background jobs (Phase 3) ---
# Uncomment to enable async scan mode via Arq. Without this, /scan runs
# synchronously on the HTTP worker (fine for local dev). With it set,
# also start `arq app.worker.WorkerSettings` in a second terminal.
# REDIS_URL=redis://localhost:6379

# --- Billing — Mollie (Phase 5b) ---
# Uncomment to enable the checkout / cancel / webhook endpoints. Without
# these the app runs in admin-assigned-plans mode (Phase 5a).
#
# Get the test key from https://www.mollie.com/dashboard/developers/api-keys.
# APP_BASE_URL must be HTTPS-reachable for Mollie's webhooks (use ngrok /
# cloudflared locally). Rotate MOLLIE_WEBHOOK_TOKEN on every deploy.
# MOLLIE_API_KEY=test_xxx
# APP_BASE_URL=https://scanner.example.com
# MOLLIE_WEBHOOK_TOKEN=$(python -c "import secrets; print(secrets.token_urlsafe(32))")

# --- Observability (Phase 7) ---
# LOG_FORMAT     text  — human-readable dev default
#                json  — one JSON object per line, ready for Loki / CloudWatch.
# LOG_LEVEL      DEBUG | INFO | WARNING | ERROR
# APP_VERSION    Stamped onto /health + every Sentry event. Set from CI (git sha).
# SENTRY_DSN     Opt-in — when set, uncaught exceptions + 5xx responses ship to Sentry.
# SENTRY_TRACES_SAMPLE_RATE   0.0 (off) to 1.0 (every request). 0.1 is sane for prod.
LOG_FORMAT=text
LOG_LEVEL=INFO
APP_VERSION=dev
# SENTRY_DSN=https://<key>@sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.1
