# Production environment template for docker-compose.prod.yml.
#
# Copy to .env (docker-compose picks it up automatically) and fill in
# every value. The stack REFUSES TO START without the required ones
# (POSTGRES_PASSWORD, JWT_SECRET, DOMAIN, TLS_EMAIL).
#
# NEVER commit the filled-in .env. It's .gitignored — keep it that way.

# --- TLS / routing --------------------------------------------------------
# Public hostname the scanner is reachable at. Must resolve (A/AAAA
# record) to the server BEFORE first boot — Let's Encrypt's HTTP-01
# challenge checks reachability over port 80.
DOMAIN=scanner.example.com
# Where Let's Encrypt sends cert-expiry nags. Use a real inbox.
TLS_EMAIL=ops@example.com

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=scanner
# REQUIRED — generate with `openssl rand -base64 32`.
POSTGRES_PASSWORD=
POSTGRES_DB=scanner

# --- Auth -----------------------------------------------------------------
# REQUIRED — generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# If this rotates, every signed-in user is logged out immediately. That's
# the correct behaviour after a suspected compromise.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=10080

# --- CORS -----------------------------------------------------------------
# Defaults to https://$DOMAIN which is almost always what you want.
# Override only if the dashboard is served from a different origin.
# ALLOWED_ORIGINS=https://scanner.example.com

# --- AI provider (optional — app runs with a NoOp analyzer without) ------
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# or:
# AI_PROVIDER=azure
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-prod

# --- Scan user-agent ------------------------------------------------------
# Sites sometimes whitelist specific strings. Keep the product name +
# a contact path so operators who see you in their logs can reach out.
SCAN_USER_AGENT=GDPR-Scanner/1.0 (+https://scanner.example.com/contact)

# --- Frontend build-time knobs -------------------------------------------
# "sync" (default) runs scans inline on the HTTP worker.
# "async" routes new scans through the Arq worker (recommended for prod).
NEXT_PUBLIC_SCAN_MODE=async

# --- Billing (Phase 5b — leave empty to stay on admin-assigned plans) ----
# Get the LIVE key at https://www.mollie.com/dashboard/developers/api-keys
# once your account is verified. Test key (`test_...`) works identically
# for sandbox deployments.
MOLLIE_API_KEY=
# APP_BASE_URL defaults to https://$DOMAIN in compose; override only if
# running behind another reverse proxy that changes the host header.
# APP_BASE_URL=https://scanner.example.com
# REQUIRED for webhooks. Rotate on every deploy.
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
MOLLIE_WEBHOOK_TOKEN=

# --- Observability (Phase 7) ----------------------------------------------
# Production defaults: JSON logs for shipper ingestion, INFO level.
# APP_VERSION should be the commit SHA from CI — easy `docker logs`
# cross-referencing when an error needs investigating later. The deploy
# workflow overwrites this line on every release.
LOG_FORMAT=json
LOG_LEVEL=INFO
APP_VERSION=dev
# Uncomment to enable Sentry. 4xx stay local, 5xx + unhandled exceptions
# ship. Cookie / Authorization headers + password-shaped extras are
# scrubbed before any event leaves the process.
# SENTRY_DSN=https://<key>@o12345.ingest.sentry.io/67890
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Container registry (Phase 7b — CI/CD) --------------------------------
# Set IMAGE_REGISTRY to the *prefix* used by the docker/build-push action.
# docker-compose.prod.yml appends "-backend:${APP_VERSION}" /
# "-frontend:${APP_VERSION}" itself.
#
# For GHCR (default in .github/workflows/ci.yml):
#   IMAGE_REGISTRY=ghcr.io/<github-owner>/<repo-name>
#
# For a self-hosted registry (Scaleway Registry, Harbor, etc.):
#   IMAGE_REGISTRY=rg.fr-par.scw.cloud/<your-namespace>/dsgvo-scanner
#
# Leaving this unset falls back to the placeholder in compose —
# `docker compose up --build` still works; `docker compose pull` will fail.
IMAGE_REGISTRY=ghcr.io/your-github-owner/dsgvo-scanner

# --- Compliance / security.txt (Phase 7c) ---------------------------------
# SECURITY_CONTACT_EMAIL   — mailto: in /.well-known/security.txt. REQUIRED.
# SECURITY_POLICY_URL      — link to your vulnerability-disclosure policy page.
# SECURITY_TXT_EXPIRES     — ISO-8601 date. MUST be <= 1 year out. Rotate yearly.
# SECURITY_ACKNOWLEDGMENTS_URL — optional hall-of-fame / credits page.
SECURITY_CONTACT_EMAIL=security@example.com
SECURITY_POLICY_URL=https://scanner.example.com/security
SECURITY_TXT_EXPIRES=2027-01-01T00:00:00Z
# SECURITY_ACKNOWLEDGMENTS_URL=https://scanner.example.com/security/credits

# --- Backups (Phase 7c) ---------------------------------------------------
# Consumed by deploy/backup.sh. Cron it daily:
#   0 3 * * * /opt/dsgvo-scanner/deploy/backup.sh >> /var/log/scanner-backup.log 2>&1
# Off-site copies (S3 / rsync to another EU region) MUST be GPG-encrypted.
BACKUP_DIR=/var/backups/scanner
# BACKUP_GPG_RECIPIENT=security@example.com
