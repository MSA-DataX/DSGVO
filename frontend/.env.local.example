# URL of the FastAPI backend. Used by app/api/scan/route.ts to proxy.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Scan execution mode (Phase 3c). Default is "sync" which hits the
# inline /scan/stream endpoint — works without Redis. Set to "async"
# to route new scans through /scan/jobs + /scan/jobs/{id}/events,
# which requires REDIS_URL in the backend .env and a running
# `arq app.worker.WorkerSettings` process.
# NEXT_PUBLIC_SCAN_MODE=async
